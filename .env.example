# Telegram API Credentials (get from https://my.telegram.org/apps)
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_from_botfather

# MongoDB Connection
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/userbot_saas?retryWrites=true&w=majority

# Redis Connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Bot Settings
BOT_USERNAME=YourUserbotBot
OWNER_ID=123456789  # Your Telegram user ID
LOG_GROUP_ID=-1001234567890  # Optional: for logging

# Encryption Key (generate via: openssl rand -hex 32)
ENCRYPTION_KEY=your_32_byte_hex_key_here

# AI Settings
AI_API_KEY=your_openai_api_key_optional
AI_MODEL=gpt-3.5-turbo

# Session Config
SESSION_EXPIRY_DAYS=30
MAX_USERS=1000
